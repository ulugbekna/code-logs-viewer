{
  "name": "code-logs-viewer",
  "displayName": "Code Logs Viewer",
  "description": "Rich webview for VS Code Output-pane log files (filtering, search, timeline, JSON).",
  "version": "0.2.0",
  "publisher": "ulugbekna",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ulugbekna/code-logs-viewer"
  },
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-logs-viewer.open",
        "title": "Open with Log Viewer",
        "category": "Logs"
      },
      {
        "command": "code-logs-viewer.showVSCodeLog",
        "title": "Show VS Code Log...",
        "category": "Logs"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "code-logs-viewer.open"
        },
        {
          "command": "code-logs-viewer.showVSCodeLog"
        }
      ],
      "editor/title": [
        {
          "command": "code-logs-viewer.open",
          "when": "resourceFilename =~ /\\.(out\\.md|log)$/i",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "code-logs-viewer.open",
          "when": "resourceFilename =~ /\\.(out\\.md|log)$/i",
          "group": "navigation@10"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "npm-run-all -p watch:tsc:*",
    "watch:tsc:ext": "tsc --noEmit --watch --project tsconfig.json",
    "watch:tsc:web": "tsc --noEmit --watch --project media/tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit && tsc --noEmit -p media/tsconfig.json",
    "lint": "eslint src shared media",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.118.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
